# Uncomment to suppress warnings coming from external libraries.
#
cxx.internal.scope = current

cxx.std = latest

using cxx
using c
using c.predefs

hxx{*}: extension = hpp
ixx{*}: extension = ipp
txx{*}: extension = tpp
cxx{*}: extension = cpp
mxx{*}: extension = cppm

h{*}: extension = h
c{*}: extension = c

# The test target for cross-testing (running tests under Wine, etc).
#
test.target = $cxx.target

# Back-end selection. See ../README.md, section "Library Back-Ends".
#
# Unwind back-ends.
# unwind_with_dbghelp and unwind_with_execinfo are set first; unwind_with_unwind
# is the fallback derived from neither of the above being active.
#
config [bool] config.libcpptrace.unwind_with_dbghelp   ?= ($cxx.target.class == 'windows')
config [bool] config.libcpptrace.unwind_with_execinfo  ?= false
config [bool] config.libcpptrace.unwind_with_unwind    ?= ($config.libcpptrace.unwind_with_dbghelp || $config.libcpptrace.unwind_with_execinfo ? false : true)
config [bool] config.libcpptrace.unwind_with_winapi    ?= false
config [bool] config.libcpptrace.unwind_with_libunwind ?= false
config [bool] config.libcpptrace.unwind_with_nothing   ?= false

# Symbol resolution back-ends.
# symbols_with_libdwarf is the default on UNIX and mingw32 (DWARF-based).
# symbols_with_dbghelp is enabled on all Windows targets (MSVC and mingw32):
# on mingw32 it supplements libdwarf to cover PDB symbols from system DLLs.
#
config [bool] config.libcpptrace.symbols_with_libdwarf     ?= ($cxx.target.class != 'windows' || $cxx.target.system == 'mingw32')
config [bool] config.libcpptrace.symbols_with_dbghelp      ?= ($cxx.target.class == 'windows')
config [bool] config.libcpptrace.symbols_with_libbacktrace ?= false
config [bool] config.libcpptrace.symbols_with_addr2line    ?= false
config [bool] config.libcpptrace.symbols_with_libdl        ?= false
config [bool] config.libcpptrace.symbols_with_nothing      ?= false

# Demangling back-ends.
#
config [bool] config.libcpptrace.demangle_with_cxxabi  ?= (!($cxx.target.class == 'windows' && $cxx.target.system != 'mingw32'))
config [bool] config.libcpptrace.demangle_with_winapi  ?= ($cxx.target.class == 'windows' && $cxx.target.system != 'mingw32')
config [bool] config.libcpptrace.demangle_with_nothing ?= false

config [bool] config.libcpptrace.build_testing ?= false

if($build.mode != 'skeleton' && $config.libcpptrace.build_testing)
  info "configured for testing \(config.libcpptrace.build_testing=true\)"
